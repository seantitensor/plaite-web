---
import AdminLayout from '../../components/admin/AdminLayout.astro';
---

<AdminLayout title="Dashboard" activePage="overview">
	<div class="overview">
		<h1>Dashboard</h1>
		<p class="subtitle">Welcome to the plaite admin dashboard.</p>

		<div class="cards">
			<a href="/admin/analytics" class="card">
				<div class="card-icon">
					<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#4A9B6B" stroke-width="2">
						<path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/>
					</svg>
				</div>
				<h2>Analytics</h2>
				<p>View active users, sessions, retention, funnels, and geographic distribution from Firebase Analytics.</p>
			</a>

			<a href="/admin/board" class="card">
				<div class="card-icon">
					<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#4A9B6B" stroke-width="2">
						<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18"/><path d="M15 3v18"/>
					</svg>
				</div>
				<h2>Roadmap</h2>
				<p>Organize work into epics like "Current Features" or "Next Release". Each feature has its own todo checklist and auto-computed progress.</p>
			</a>
		</div>
	</div>
</AdminLayout>

<style>
	.overview h1 {
		font-size: 1.5rem;
		font-weight: 700;
		color: #1e293b;
		margin-bottom: 0.25rem;
	}

	.subtitle {
		color: #64748b;
		font-size: 0.95rem;
		margin-bottom: 2rem;
	}

	.cards {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
		max-width: 700px;
	}

	.card {
		background: #fff;
		border-radius: 12px;
		padding: 2rem;
		border: 1px solid #e2e8f0;
		text-decoration: none;
		transition: box-shadow 0.2s, transform 0.2s;
	}

	.card:hover {
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
		transform: translateY(-2px);
	}

	.card-icon {
		margin-bottom: 1rem;
	}

	.card h2 {
		font-size: 1.1rem;
		font-weight: 700;
		color: #1e293b;
		margin-bottom: 0.5rem;
	}

	.card p {
		font-size: 0.85rem;
		color: #64748b;
		line-height: 1.5;
	}

	@media (max-width: 600px) {
		.cards {
			grid-template-columns: 1fr;
		}
	}
</style>
