---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Privacy Policy - plaite">
	<Header showBack />

	<section class="policy-page">
		<h1 class="section-title">Privacy Policy</h1>
		<p class="section-subtitle">Your trust is important to us. Learn how we collect, use, and protect your information.</p>
		<p class="effective-date">Effective Date: July 12th, 2025</p>

		<div class="policy-content">
			<p>At <strong>plaite</strong>, we respect your privacy and are committed to protecting your personal information. This Privacy Policy explains how we collect, use, and safeguard your data when you use our mobile application.</p>
		</div>

		<div class="policy-content">
			<h2>Information We Collect</h2>

			<h3>Data You Provide</h3>
			<ul>
				<li><strong>Dietary Preferences:</strong> We collect your dietary preferences (such as vegan, vegetarian, keto, gluten-free, etc.) to personalize your recipe recommendations.</li>
				<li><strong>Recipe Interactions:</strong> We track which recipes you swipe right (like) or left (dislike) to improve our AI-powered recommendation system.</li>
			</ul>

			<h3>Automatically Collected Data</h3>
			<ul>
				<li><strong>Usage Analytics:</strong> We may collect anonymous usage data to improve app performance and user experience.</li>
				<li><strong>Device Information:</strong> Basic device information for app functionality and troubleshooting.</li>
			</ul>
		</div>

		<div class="policy-content">
			<h2>How We Use Your Information</h2>
			<p>We use the collected data to:</p>
			<ul>
				<li>Provide personalized recipe recommendations based on your preferences</li>
				<li>Improve our AI algorithm by analyzing recipe interaction patterns</li>
				<li>Enhance the overall user experience and app functionality</li>
				<li>Analyze usage trends to develop new features</li>
			</ul>
		</div>

		<div class="policy-content">
			<h2>Data Storage and Security</h2>
			<ul>
				<li>Your data is stored securely using <strong>industry-standard encryption</strong></li>
				<li>We implement appropriate technical and organizational measures to protect your information</li>
				<li>Your recipe preferences and swipe data are associated with your account to maintain personalization</li>
			</ul>
		</div>

		<div class="policy-content">
			<h2>Data Sharing</h2>
			<p>We <strong>do not sell, trade, or otherwise transfer</strong> your personal information to third parties, except:</p>
			<ul>
				<li>When required by law or to protect our rights</li>
				<li>With service providers who assist in app functionality (under strict confidentiality agreements)</li>
				<li>In anonymized, aggregated form for analytics purposes</li>
			</ul>
		</div>

		<div class="policy-content">
			<h2>Your Rights</h2>
			<p>You have the right to:</p>
			<ul>
				<li>Access the personal data we hold about you</li>
				<li>Request correction of inaccurate data</li>
				<li>Request deletion of your data</li>
			</ul>
		</div>

		<div class="policy-content">
			<h2>Data Retention</h2>
			<p>We retain your data for as long as your account is active or as needed to provide services. You may request deletion of your data at any time by contacting us.</p>
		</div>

		<div class="policy-content">
			<h2>Children's Privacy</h2>
			<p>Our app is not intended for children under 13. We do not knowingly collect personal information from children under 13. If you believe we have collected such information, please contact us immediately.</p>
		</div>

		<div class="policy-content">
			<h2>Changes to This Policy</h2>
			<p>We may update this Privacy Policy from time to time. We will notify you of any changes by posting the new Privacy Policy on this page and updating the "Effective Date."</p>
		</div>

		<div class="contact-info">
			<h3>Contact Us</h3>
			<p>If you have any questions about this Privacy Policy, please contact us at:</p>
			<p><strong>Email:</strong> <a href="mailto:dennis.dellacorte@plaite.io">dennis.dellacorte@plaite.io</a></p>
			<p><strong>Website:</strong> <a href="https://plaite.io" target="_blank" rel="noopener">https://plaite.io</a></p>
		</div>
	</section>

	<Footer />
</Layout>

<style>
	.policy-page {
		padding: 7rem 5% 3rem;
		max-width: 900px;
		margin: 0 auto;
	}

	.section-title {
		text-align: center;
		font-size: 2.8rem;
		margin-bottom: 1rem;
		font-weight: 700;
		color: var(--color-primary);
	}

	.section-subtitle {
		text-align: center;
		font-size: 1.15rem;
		color: var(--color-text-muted);
		margin-bottom: 1.5rem;
		max-width: 700px;
		margin-left: auto;
		margin-right: auto;
	}

	.effective-date {
		text-align: center;
		font-size: 1.05rem;
		color: var(--color-primary);
		font-weight: 600;
		margin-bottom: 2.5rem;
	}

	.policy-content {
		padding: 0.5rem 0;
		margin-bottom: 0.5rem;
	}

	.policy-content h2 {
		font-size: 1.8rem;
		margin: 2.5rem 0 1rem;
		font-weight: 700;
		color: var(--color-primary);
	}

	.policy-content h3 {
		font-size: 1.3rem;
		margin: 1.5rem 0 0.75rem;
		font-weight: 600;
		color: var(--color-text);
	}

	.policy-content p {
		margin-bottom: 1.2rem;
		color: var(--color-text);
		opacity: 0.9;
		font-size: 1.05rem;
		line-height: 1.7;
	}

	.policy-content ul {
		list-style: none;
		margin: 1rem 0;
		padding-left: 0.5rem;
	}

	.policy-content ul li {
		padding: 0.5rem 0;
		padding-left: 1.8rem;
		position: relative;
		color: var(--color-text);
		opacity: 0.9;
		font-size: 1.05rem;
		line-height: 1.6;
	}

	.policy-content ul li::before {
		content: '-';
		position: absolute;
		left: 0;
		color: var(--color-primary);
		font-weight: bold;
		font-size: 1.2rem;
	}

	.contact-info {
		background: var(--color-primary-light);
		padding: 2.5rem;
		border-radius: var(--radius-lg);
		margin-top: 3rem;
		text-align: center;
	}

	.contact-info h3 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
		color: var(--color-primary);
		font-weight: 700;
	}

	.contact-info p {
		margin-bottom: 0.8rem;
		font-size: 1.05rem;
	}

	.contact-info a {
		color: var(--color-primary);
		font-weight: 600;
		transition: opacity 0.3s ease;
	}

	.contact-info a:hover {
		opacity: 0.8;
	}

	@media (max-width: 768px) {
		.policy-page {
			padding: 5.5rem 4% 2rem;
		}
		.section-title {
			font-size: 2.2rem;
		}
		.policy-content h2 {
			font-size: 1.5rem;
		}
	}

	@media (max-width: 480px) {
		.policy-page {
			padding: 5rem 3% 1.5rem;
		}
		.section-title {
			font-size: 1.9rem;
		}
		.policy-content h2 {
			font-size: 1.4rem;
			padding-left: 1rem;
		}
		.policy-content p,
		.policy-content ul li {
			font-size: 0.95rem;
		}
		.contact-info {
			padding: 1.8rem 1.2rem;
		}
	}
</style>
