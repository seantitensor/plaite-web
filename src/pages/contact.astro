---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact Us - plaite">
	<Header showBack />

	<section class="contact-page">
		<h1 class="section-title">Contact Us</h1>
		<p class="section-subtitle">Get in touch with us for any questions, support, or feedback.</p>

		<div class="form-container">
			<form class="contact-form" action="#" method="post">
				<div class="form-group">
					<label for="name">Name</label>
					<input type="text" id="name" name="name" required />
				</div>
				<div class="form-group">
					<label for="email">Email</label>
					<input type="email" id="email" name="email" required />
				</div>
				<div class="form-group">
					<label for="message">Message</label>
					<textarea id="message" name="message" required></textarea>
				</div>
				<button type="submit" class="submit-button">Send Message</button>
			</form>
		</div>

		<div class="contact-info">
			<h3>Contact Information</h3>
			<p><strong>Email:</strong> <a href="mailto:dennis.dellacorte@plaite.io">dennis.dellacorte@plaite.io</a></p>
			<p><strong>Website:</strong> <a href="https://plaite.io" target="_blank" rel="noopener">https://plaite.io</a></p>
		</div>
	</section>

	<Footer />
</Layout>

<style>
	.contact-page {
		padding: 7rem 5% 3rem;
		max-width: 900px;
		margin: 0 auto;
	}

	.section-title {
		text-align: center;
		font-size: 2.8rem;
		margin-bottom: 1rem;
		font-weight: 700;
		color: var(--color-primary);
	}

	.section-subtitle {
		text-align: center;
		font-size: 1.15rem;
		color: var(--color-text-muted);
		margin-bottom: 3rem;
		max-width: 700px;
		margin-left: auto;
		margin-right: auto;
	}

	.form-container {
		padding: 0.5rem;
		margin-bottom: 1rem;
	}

	.contact-form {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.form-group {
		display: flex;
		flex-direction: column;
	}

	.form-group label {
		font-size: 1.05rem;
		font-weight: 600;
		color: var(--color-primary);
		margin-bottom: 0.5rem;
	}

	.form-group input,
	.form-group textarea {
		padding: 1rem;
		border: 1px solid rgba(0, 0, 0, 0.1);
		border-radius: var(--radius-sm);
		font-size: 1rem;
		font-family: var(--font-family);
		color: var(--color-text);
		background: var(--color-bg);
		transition: border-color 0.3s ease, box-shadow 0.3s ease;
	}

	.form-group input:focus,
	.form-group textarea:focus {
		outline: none;
		border-color: var(--color-primary);
		box-shadow: 0 0 0 3px rgba(74, 155, 107, 0.15);
	}

	.form-group textarea {
		min-height: 150px;
		resize: vertical;
	}

	.submit-button {
		background: var(--color-primary-gradient);
		color: var(--color-white);
		padding: 1rem 2.5rem;
		border-radius: var(--radius-pill);
		font-weight: 600;
		font-size: 1.05rem;
		font-family: var(--font-family);
		border: none;
		cursor: pointer;
		transition: transform 0.3s ease, box-shadow 0.3s ease;
		align-self: center;
	}

	.submit-button:hover {
		transform: translateY(-2px);
		box-shadow: 0 10px 30px rgba(74, 155, 107, 0.4);
	}

	.contact-info {
		background: var(--color-primary-light);
		padding: 2.5rem;
		border-radius: var(--radius-lg);
		margin-top: 3rem;
		text-align: center;
	}

	.contact-info h3 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
		color: var(--color-primary);
		font-weight: 700;
	}

	.contact-info p {
		margin-bottom: 0.8rem;
		font-size: 1.05rem;
	}

	.contact-info a {
		color: var(--color-primary);
		font-weight: 600;
		transition: opacity 0.3s ease;
	}

	.contact-info a:hover {
		opacity: 0.8;
	}

	@media (max-width: 768px) {
		.contact-page {
			padding: 5.5rem 4% 2rem;
		}
		.section-title {
			font-size: 2.2rem;
		}
	}

	@media (max-width: 480px) {
		.contact-page {
			padding: 5rem 3% 1.5rem;
		}
		.section-title {
			font-size: 1.9rem;
		}
		.form-group input,
		.form-group textarea {
			padding: 0.85rem;
			font-size: 0.95rem;
		}
		.contact-info {
			padding: 1.8rem 1.2rem;
		}
	}
</style>
