# Path to your Firebase service account JSON file (server-side: Admin SDK + Analytics)
GOOGLE_APPLICATION_CREDENTIALS=./path/to/service-account.json

# Firebase Client SDK (public, used in browser for Auth)
PUBLIC_FIREBASE_API_KEY=your_api_key
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your-project-id
PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
PUBLIC_FIREBASE_APP_ID=your_app_id

# Google Analytics Data API (GA4 property ID)
GA_PROPERTY_ID=your_ga4_property_id
